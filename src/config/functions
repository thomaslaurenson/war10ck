# function: wf_sshfs_mount
wf_sshfs_mount() {
    local SSHFS_CONFIG_DIR="$HOME/.war10ck"
    local SSHFS_RECENT="$SSHFS_CONFIG_DIR/.sshfs_recent"
    local SSHFS_FAVORITES="$SSHFS_CONFIG_DIR/.sshfs_favorites"
    
    # Ensure config directory exists
    mkdir -p "$SSHFS_CONFIG_DIR"
    touch "$SSHFS_RECENT" "$SSHFS_FAVORITES"
    
    # Get SSH config
    local CONFIG="$HOME/.ssh/config"
    if [ ! -f "$CONFIG" ]; then
        echo "[!] SSH config not found at $CONFIG"
        return 1
    fi
    
    # Select host
    local HOSTS=$(grep -E '^Host\s+' "$CONFIG" | grep -v '*' | awk '{print $2}')
    echo "[*] Available SSH Hosts:"
    local HOST
    PS3="[*] Select host: "
    select HOST in $HOSTS; do
        if [ -n "$HOST" ]; then
            break
        fi
    done
    
    # Extract SSH details
    local HOSTNAME=$(awk "/Host $HOST/{f=1} f && /HostName/{print \$2; exit}" "$CONFIG")
    local PORT=$(awk "/Host $HOST/{f=1} f && /Port/{print \$2; exit}" "$CONFIG")
    local USER=$(awk "/Host $HOST/{f=1} f && /User/{print \$2; exit}" "$CONFIG")
    
    # Determine remote directory
    local REMOTE_TARGET_DIR="$1"
    
    if [ -z "$REMOTE_TARGET_DIR" ]; then
        echo ""
        echo "[*] Select remote directory:"
        
        # Build directory options
        local dir_options=()
        dir_options+=("Home directory (~)")
        dir_options+=("Root directory (/)")
        
        # Add favorites for this host
        local fav_count=0
        while IFS='|' read -r fav_host fav_path fav_label; do
            if [ "$fav_host" = "$HOST" ]; then
                dir_options+=("Favorite: $fav_label ($fav_path)")
                ((fav_count++))
            fi
        done < "$SSHFS_FAVORITES"
        
        # Add recent paths for this host
        local recent_count=0
        while IFS='|' read -r recent_host recent_path; do
            if [ "$recent_host" = "$HOST" ] && [ "$recent_count" -lt 3 ]; then
                dir_options+=("Recent: $recent_path")
                ((recent_count++))
            fi
        done < <(tac "$SSHFS_RECENT" | awk '!seen[$0]++')
        
        dir_options+=("Custom path")
        dir_options+=("Cancel")
        
        PS3="[*] Select directory (1-${#dir_options[@]}): "
        select dir_choice in "${dir_options[@]}"; do
            case "$dir_choice" in
                "Home directory (~)")
                    REMOTE_TARGET_DIR="~"
                    break
                    ;;
                "Root directory (/)")
                    REMOTE_TARGET_DIR="/"
                    break
                    ;;
                "Custom path")
                    echo -n "[?] Enter remote path: "
                    read -r REMOTE_TARGET_DIR
                    break
                    ;;
                "Cancel")
                    echo "[*] Cancelled"
                    return 0
                    ;;
                Favorite:*)
                    REMOTE_TARGET_DIR=$(echo "$dir_choice" | sed 's/Favorite: .* (\(.*\))/\1/')
                    break
                    ;;
                Recent:*)
                    REMOTE_TARGET_DIR=$(echo "$dir_choice" | sed 's/Recent: //')
                    break
                    ;;
                *)
                    if [ -n "$dir_choice" ]; then
                        break
                    fi
                    echo "[!] Invalid selection"
                    ;;
            esac
        done
    fi
    
    # Mount options
    local mount_opts="reconnect,compression=yes,follow_symlinks"
    
    # Confirmation
    echo ""
    echo "[*] Mount Summary:"
    echo "    Host:        $HOST"
    echo "    Remote Path: $REMOTE_TARGET_DIR"
    echo "    Options:     $mount_opts"
    echo -n "[?] Proceed with mount? [Y/n]: "
    read -r confirm
    if [[ "$confirm" =~ ^[Nn]$ ]]; then
        echo "[*] Cancelled"
        return 0
    fi
    
    # Set up mount directory
    local BASE_MOUNT_DIR="$HOME/sshfs"
    mkdir -p "$BASE_MOUNT_DIR"
    local LOCAL_MOUNT_POINT="$BASE_MOUNT_DIR/$HOST"
    
    # Check if already mounted
    if mountpoint -q "$LOCAL_MOUNT_POINT" 2>/dev/null; then
        echo "[!] $HOST is already mounted at $LOCAL_MOUNT_POINT"
        return 1
    fi
    
    mkdir -p "$LOCAL_MOUNT_POINT"
    
    # Perform mount
    echo "[*] Mounting..."
    if sshfs "$HOST":"$REMOTE_TARGET_DIR" "$LOCAL_MOUNT_POINT" -o "$mount_opts"; then
        echo "[*] Successfully mounted!"
        
        # Save to recent paths (remove duplicates, keep most recent, max 20 entries)
        grep -v "^${HOST}|${REMOTE_TARGET_DIR}$" "$SSHFS_RECENT" > "$SSHFS_RECENT.tmp" 2>/dev/null || true
        echo "$HOST|$REMOTE_TARGET_DIR" >> "$SSHFS_RECENT.tmp"
        tail -n 20 "$SSHFS_RECENT.tmp" > "$SSHFS_RECENT" && rm -f "$SSHFS_RECENT.tmp"
        
        # Offer to save as favorite
        echo ""
        echo -n "[?] Save this as a favorite? [y/N]: "
        read -r save_favorite
        if [[ "$save_favorite" =~ ^[Yy]$ ]]; then
            echo -n "[?] Enter a label for this favorite: "
            read -r fav_label
            if [ -n "$fav_label" ]; then
                # Check if this exact favorite already exists
                if grep -q "^${HOST}|${REMOTE_TARGET_DIR}|${fav_label}$" "$SSHFS_FAVORITES" 2>/dev/null; then
                    echo "[*] This favorite already exists"
                else
                    echo "$HOST|$REMOTE_TARGET_DIR|$fav_label" >> "$SSHFS_FAVORITES"
                    echo "[*] Saved as favorite: $fav_label"
                fi
            fi
        fi
    else
        echo "[!] Failed to mount"
        rmdir "$LOCAL_MOUNT_POINT" 2>/dev/null
        return 1
    fi
}

# function: wf_sshfs_umount
wf_sshfs_umount() {
    BASE_MOUNT_DIR="$HOME/sshfs"
    # Find all active mounts
    ACTIVE_MOUNTS=()
    MOUNT_NAMES=()
    for dir in "$BASE_MOUNT_DIR"/*; do
        if [ -d "$dir" ] && mountpoint -q "$dir"; then
            ACTIVE_MOUNTS+=("$dir")
            MOUNT_NAMES+=("$(basename "$dir")")
        fi
    done
    # Check if there are any active mounts
    if [ ${#ACTIVE_MOUNTS[@]} -eq 0 ]; then
        echo "[!] No active sshfs mounts found in $BASE_MOUNT_DIR"
        return 1
    fi
    # Display active mounts with their info
    echo "Active SSHFS mounts:"
    PS3="Select mount to unmount (or 0 to cancel): "
    select MOUNT_NAME in "${MOUNT_NAMES[@]}"; do
        if [ -n "$MOUNT_NAME" ]; then
            MOUNT_POINT="$BASE_MOUNT_DIR/$MOUNT_NAME"
            echo "[*] Unmounting: $MOUNT_NAME ($MOUNT_POINT)"
            if fusermount -u "$MOUNT_POINT" 2>/dev/null || umount "$MOUNT_POINT" 2>/dev/null; then
                echo "[*] Successfully unmounted"
                rmdir "$MOUNT_POINT"
                echo "[*] Removed directory: $MOUNT_POINT"
            else
                echo "[!] Failed to unmount $MOUNT_POINT"
                return 1
            fi
            break
        elif [ "$REPLY" -eq 0 ]; then
            echo "[*] Cancelled"
            return 0
        fi
    done
}

# function: wf_ramdisk
wf_ramdisk () {
    ramdisk_path="$HOME/ramdisk"
    if [ ! -d "$ramdisk_path" ]; then
        echo "Creating RAM disk directory..."
        mkdir $ramdisk_path
    fi
    if [[ "$1" = "mount" ]]; then
        echo "Mounting RAM disk..."
        sudo mount -t tmpfs -o size=2048M tmpfs $ramdisk_path
    elif [[ "$1" = "umount" ]]; then
        echo "Unmounting RAM disk..."
        sudo umount $ramdisk_path
    else
        echo "Usage:"
        echo "ramdisk mount -- mounts RAM disk"
        echo "ramdisk umount -- unmounts RAM disk"
    fi
}

# function: wf_transmission_bind
wf_transmission_bind () {
    # Kill transmission-daemon if it is running
    transmission_da_pids=$(pgrep transmission-da)
    if [ "$transmission_da_pids" ]; then
        echo "Killing transmission-daemon processes..."
        sudo pkill transmission-da
    fi
    # Get VPN IP to bind to
    # bind_address=$(ip -br addr show moz0 | awk '{print $3}')
    bind_address=$(curl http://ipecho.net/plain; echo)
    # If IP wasn't found then quit
    if [ -z $bind_address ]; then
        echo "VPN doesn't seem to be up. Will not start transmission-daemon"
        exit 1
    fi
    # Start transmission-daemon
    transmission-daemon --rpc-bind-address=127.0.0.1 --bind-address-ipv4=$bind_address
    echo "transmission-daemon started and bound to address $bind_address"
}
