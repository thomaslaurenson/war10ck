        hasWikiEnabled=$(jq -c '.hasWikiEnabled | tostring' <<< "$JSON"  | tr -d '"')
        nameWithOwner=$(jq -c '.nameWithOwner' <<< "$JSON"  | tr -d '"')
        echo "[*] $nameWithOwner | $hasWikiEnabled"
        # Disable the repository wiki if it is enabled
        if [ "$hasWikiEnabled" = "true" ]; then
            echo "[*] Disabling repository wiki..."
            gh repo edit "$nameWithOwner" --enable-wiki=false
        fi
    done
}

# function: w_sshfs_mount
w_sshfs_mount() {
    # Helper defined inline and auto-removed on function exit — never leaks to shell
    _w_sshfs_collect_configs() {
        local file="$1"
        [ -f "$file" ] || return
        echo "$file"
        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*[Ii]nclude[[:space:]]+(.+)$ ]] || continue
            local pattern="${BASH_REMATCH[1]}"
            pattern="${pattern/#\~/$HOME}"
            for inc in $pattern; do
                [ -f "$inc" ] && _w_sshfs_collect_configs "$inc"
            done
        done < "$file"
    }
    trap 'unset -f _w_sshfs_collect_configs' RETURN

    local SSHFS_CONFIG_DIR="$HOME/.war10ck"
    local SSHFS_FAVORITES="$SSHFS_CONFIG_DIR/.sshfs_favorites"

    # Ensure config directory and favourites file exist
    mkdir -p "$SSHFS_CONFIG_DIR"
    touch "$SSHFS_FAVORITES"

    local HOST REMOTE_TARGET_DIR

    # Favourites fast-path: if any favourites exist, offer them upfront
    if [ -s "$SSHFS_FAVORITES" ]; then
        echo "[*] Saved favourites:"
        local fav_labels=() fav_hosts=() fav_paths=()
        while IFS='|' read -r fav_host fav_path fav_label; do
            fav_labels+=("$fav_label ($fav_host:$fav_path)")
            fav_hosts+=("$fav_host")
            fav_paths+=("$fav_path")
        done < "$SSHFS_FAVORITES"
        fav_labels+=("New mount")

        local fav_choice
        PS3="[*] Select favourite or new mount: "
        select fav_choice in "${fav_labels[@]}"; do
            if [ -n "$fav_choice" ]; then
                break
            fi
            echo "[!] Invalid selection"
        done

        if [ "$fav_choice" != "New mount" ]; then
            local idx
            for idx in "${!fav_labels[@]}"; do
                if [ "${fav_labels[$idx]}" = "$fav_choice" ]; then
                    HOST="${fav_hosts[$idx]}"
                    REMOTE_TARGET_DIR="${fav_paths[$idx]}"
                    break
                fi
            done
        fi
    fi

    # If no favourite was selected, do full host + directory selection
    if [ -z "$HOST" ]; then
        local CONFIG="$HOME/.ssh/config"
        if [ ! -f "$CONFIG" ]; then
            echo "[!] SSH config not found at $CONFIG"
            return 1
        fi

        # Collect all hosts across all config files (deduplicated)
        local -a ALL_CONFIGS
        mapfile -t ALL_CONFIGS < <(_w_sshfs_collect_configs "$CONFIG")
        local HOSTS
        HOSTS=$(grep -h -E '^Host[[:space:]]+' "${ALL_CONFIGS[@]}" 2>/dev/null \
            | grep -v '[*?]' \
            | awk '{for(i=2;i<=NF;i++) print $i}' \
            | sort -u)

        echo "[*] Available SSH Hosts:"
        PS3="[*] Select host: "
        select HOST in $HOSTS; do
            if [ -n "$HOST" ]; then
                break
            fi
        done

        echo "[*] Select remote directory:"
        local dir_options=()
        dir_options+=("Home directory (~)")
        dir_options+=("Root directory (/)")
        dir_options+=("Custom path")
        dir_options+=("Cancel")

        PS3="[*] Select directory (1-${#dir_options[@]}): "
        select dir_choice in "${dir_options[@]}"; do
            case "$dir_choice" in
                "Home directory (~)")
                    REMOTE_TARGET_DIR="~"
                    break
                    ;;
                "Root directory (/)")
                    REMOTE_TARGET_DIR="/"
                    break
                    ;;
                "Custom path")
                    echo -n "[?] Enter remote path: "
                    read -r REMOTE_TARGET_DIR
                    break
                    ;;
                "Cancel")
                    echo "[*] Cancelled"
                    return 0
                    ;;
                *)
                    echo "[!] Invalid selection"
                    ;;
            esac
        done
    fi

    # Mount options
    local mount_opts="reconnect,compression=yes,follow_symlinks"

    # Confirmation
    echo "[*] Mount Summary:"
    echo "    Host:        $HOST"
    echo "    Remote Path: $REMOTE_TARGET_DIR"
    echo "    Options:     $mount_opts"
    echo -n "[?] Proceed with mount? [Y/n]: "
    read -r confirm
    if [[ "$confirm" =~ ^[Nn]$ ]]; then
        echo "[*] Cancelled"
        return 0
    fi

    # Set up mount directory
    local BASE_MOUNT_DIR="$HOME/sshfs"
    mkdir -p "$BASE_MOUNT_DIR"
    local LOCAL_MOUNT_POINT="$BASE_MOUNT_DIR/$HOST"

    # Check if already mounted
    if mountpoint -q "$LOCAL_MOUNT_POINT" 2>/dev/null; then
        echo "[!] $HOST is already mounted at $LOCAL_MOUNT_POINT"
        return 1
    fi

    mkdir -p "$LOCAL_MOUNT_POINT"

    # Perform mount
    echo "[*] Mounting..."
    if sshfs "$HOST":"$REMOTE_TARGET_DIR" "$LOCAL_MOUNT_POINT" -o "$mount_opts"; then
        echo "[*] Successfully mounted $HOST:$REMOTE_TARGET_DIR at $LOCAL_MOUNT_POINT"

        # Offer to save as favourite
        echo -n "[?] Save this as a favourite? [y/N]: "
        read -r save_favourite
        if [[ "$save_favourite" =~ ^[Yy]$ ]]; then
            echo -n "[?] Enter a label for this favourite: "
            read -r fav_label
            if [ -n "$fav_label" ]; then
                if grep -q "^${HOST}|${REMOTE_TARGET_DIR}|${fav_label}$" "$SSHFS_FAVORITES" 2>/dev/null; then
                    echo "[*] This favourite already exists"
                else
                    echo "$HOST|$REMOTE_TARGET_DIR|$fav_label" >> "$SSHFS_FAVORITES"
                    echo "[*] Saved as favourite: $fav_label"
                fi
            fi
        fi
    else
        echo "[!] Failed to mount"
        rmdir "$LOCAL_MOUNT_POINT" 2>/dev/null
        return 1
    fi
}

# function: w_sshfs_umount
w_sshfs_umount() {
    local BASE_MOUNT_DIR="$HOME/sshfs"
    local -a ACTIVE_MOUNTS=()
    local -a MOUNT_NAMES=()
    for dir in "$BASE_MOUNT_DIR"/*; do
        if [ -d "$dir" ] && mountpoint -q "$dir"; then
            ACTIVE_MOUNTS+=("$dir")
            MOUNT_NAMES+=("$(basename "$dir")")
        fi
    done
    if [ ${#ACTIVE_MOUNTS[@]} -eq 0 ]; then
        echo "[!] No active sshfs mounts found in $BASE_MOUNT_DIR"
        return 1
    fi
    echo "[*] Active SSHFS mounts:"
    PS3="[*] Select mount to unmount (or 0 to cancel): "
    select MOUNT_NAME in "${MOUNT_NAMES[@]}"; do
        if [ -n "$MOUNT_NAME" ]; then
            local MOUNT_POINT="$BASE_MOUNT_DIR/$MOUNT_NAME"
            echo "[*] Unmounting: $MOUNT_NAME ($MOUNT_POINT)"
            if fusermount -u "$MOUNT_POINT" 2>/dev/null || umount "$MOUNT_POINT" 2>/dev/null; then
                echo "[*] Successfully unmounted"
                rmdir "$MOUNT_POINT"
                echo "[*] Removed directory: $MOUNT_POINT"
            else
                echo "[!] Failed to unmount $MOUNT_POINT"
                return 1
            fi
            break
        elif [[ "$REPLY" == "0" ]]; then
            echo "[*] Cancelled"
            return 0
        fi
    done
}

# function: w_ramdisk
w_ramdisk () {
    ramdisk_path="$HOME/ramdisk"
    if [ ! -d "$ramdisk_path" ]; then
        echo "Creating RAM disk directory..."
        mkdir $ramdisk_path
    fi
    if [[ "$1" = "mount" ]]; then
        echo "Mounting RAM disk..."
        sudo mount -t tmpfs -o size=2048M tmpfs $ramdisk_path
    elif [[ "$1" = "umount" ]]; then
        echo "Unmounting RAM disk..."
        sudo umount $ramdisk_path
    else
        echo "Usage:"
        echo "ramdisk mount -- mounts RAM disk"
        echo "ramdisk umount -- unmounts RAM disk"
    fi
}

# function: w_transmission_bind
w_transmission_bind () {
    # Kill transmission-daemon if it is running
    transmission_da_pids=$(pgrep transmission-da)
    if [ "$transmission_da_pids" ]; then
        echo "Killing transmission-daemon processes..."
        sudo pkill transmission-da
    fi
    # Get VPN IP to bind to
    # bind_address=$(ip -br addr show moz0 | awk '{print $3}')
    bind_address=$(curl http://ipecho.net/plain; echo)
    # If IP wasn't found then quit
    if [ -z $bind_address ]; then
        echo "VPN doesn't seem to be up. Will not start transmission-daemon"
        exit 1
    fi
    # Start transmission-daemon
    transmission-daemon --rpc-bind-address=127.0.0.1 --bind-address-ipv4=$bind_address
    echo "transmission-daemon started and bound to address $bind_address"
}
