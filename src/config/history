# BETTER BASH HISTORY

# Explicit history file location
export HISTFILE="$HOME/.bash_history"

# Include timestamps in history (format: YYYY-MM-DD HH:MM:SS)
export HISTTIMEFORMAT="%F %T "

# Set history size
export HISTSIZE=10000
export HISTFILESIZE=50000

# Ignore consecutive duplicate commands
# erasedups is intentionally omitted — it silently drops entries written by
# other sessions when syncing, causing cross-session history loss
export HISTCONTROL=ignoredups

# Append history instead of overwriting when shells exit
shopt -s histappend

# Keep multi-line commands as a single entry with newlines
shopt -s cmdhist
shopt -s lithist

# Sync history across all open sessions after each command:
#   history -a  flush this session's new entries to disk
#   history -n  read back new entries written by other sessions
# Appends to PROMPT_COMMAND rather than overwriting it so other tools
# (e.g., virtualenv) are not broken
PROMPT_COMMAND="${PROMPT_COMMAND:+${PROMPT_COMMAND%;}; }history -a; history -n"
export PROMPT_COMMAND
