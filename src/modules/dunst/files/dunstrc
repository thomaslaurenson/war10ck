[global]
    monitor = 0
    follow = mouse
    width = 300
    height = 300
    origin = top-right
    offset = 10x32
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 8
    frame_width = 2
    frame_color = "#00FF00"
    separator_color = frame

    sort = yes
    font = monospace 9
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 0
    max_icon_size = 64

    sticky_history = yes
    history_length = 20
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 0
    ignore_dbusclose = false

[urgency_low]
    background = "#0a0a0a"
    foreground = "#666666"
    frame_color = "#0a0a0a"
    timeout = 5

[urgency_normal]
    background = "#0a0a0a"
    foreground = "#f8f8f8"
    frame_color = "#00FF00"
    timeout = 8

[urgency_critical]
    background = "#0a0a0a"
    foreground = "#f8f8f8"
    frame_color = "#ff0000"
    timeout = 0
