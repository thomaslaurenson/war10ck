# Work laptop (crossroads) overrides
set $internal eDP-1
set $external DP-1

# WS 1-3 on laptop, WS 4-6 on external (fall back to laptop if unplugged)
workspace 1 output $internal
workspace 2 output $internal
workspace 3 output $internal
workspace 4 output $external $internal
workspace 5 output $external $internal
workspace 6 output $external $internal
