# Work laptop (crossroads) overrides
set $internal eDP-1
set $external DP-1

# Workspace-to-output assignments
# WS 1-3 on laptop, WS 4-6 on external (fall back to laptop if unplugged)
workspace 1 output eDP-1
workspace 2 output eDP-1
workspace 3 output eDP-1
workspace 4 output DP-1 eDP-1
workspace 5 output DP-1 eDP-1
workspace 6 output DP-1 eDP-1
